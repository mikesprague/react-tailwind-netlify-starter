{
  "name": "react-tailwindcss-netlify-starter",
  "version": "0.1.0",
  "type": "module",
  "description": "My project template for a barebones React/Tailwind CSS PWA front-end hosted on Netlify with an example Netlify function that can be used on the back-end",
  "private": true,
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@11.17.0",
  "scripts": {
    "build": "npx vite build && npm run lambda:build",
    "clean": "rm -rf ./build && rm -rf ./lambda",
    "dev:vite": "npx vite serve --port $PORT",
    "format": "npx oxfmt src",
    "format:check": "npx oxfmt --check src",
    "lambda:build": "npx netlify functions:build --src ./src/functions",
    "lambda:serve": "npx netlify functions:serve --functions ./src/functions",
    "lint": "npx oxlint .",
    "prebuild": "npm run clean",
    "preview": "npx vite preview",
    "start": "npx concurrently 'npm run dev' 'npm run lambda:serve' --names '📦,💻' --prefix '[{name}] ' --kill-others",
    "test": "npm run format:check && npm run lint && npm run typecheck",
    "typecheck": "npx tsc --noEmit"
  },
  "keywords": [],
  "repository": {
    "url": "https://github.com/mikesprague/react-tailwindcss-netlify-starter"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "homepage": "https://github.com/mikesprague/react-tailwindcss-netlify-starter",
  "license": "MIT",
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cross-env": "10.1.0",
    "dayjs": "1.11.21",
    "dotenv": "17.4.2",
    "he": "1.2.0",
    "jotai": "2.20.1",
    "lucide-react": "1.22.0",
    "nanoid": "5.1.16",
    "radix-ui": "1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "5.6.0",
    "shadcn": "4.12.0",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@netlify/functions": "5.3.0",
    "@netlify/vite-plugin": "2.12.8",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "cssnano": "8.0.2",
    "cz-git": "1.13.1",
    "globals": "17.7.0",
    "netlify-cli": "26.1.0",
    "oxfmt": "0.57.0",
    "oxlint": "1.71.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-pwa": "1.3.0"
  },
  "overrides": {
    "@fastify/static": "^9.1.3",
    "@isaacs/brace-expansion": "^5.0.1",
    "ajv": "^8.20.0",
    "brace-expansion": "^5.0.6",
    "braces": "^3.0.3",
    "esbuild": "^0.28.1",
    "fastify": "^5.8.5",
    "file-type": "^22.0.1",
    "glob": "^13.0.6",
    "h3": "^1.15.11",
    "micromatch": "^4.0.8",
    "minimatch": "^10.2.5",
    "qs": "^6.15.2",
    "rollup": "^4.62.0",
    "serialize-javascript": "^7.0.5",
    "svgo": "^4.0.1",
    "tar": "^7.5.16",
    "yauzl": "^3.4.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "26.3.0",
    "npm": "11.17.0"
  },
  "allowScripts": {
    "netlify-cli@26.1.0": true,
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "@parcel/watcher@2.5.6": true,
    "unix-dgram@2.0.7": true
  }
}
